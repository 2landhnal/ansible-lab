bind {{ ansible_host  }}
port {{ sentinel_port | default(26379) }}
logfile {{ sentinel_logfile }}
timeout {{ sentinel_timeout | default(300) }}

sentinel monitor {{ redis_master_name | default('mymaster') }} {{ redis_master_host }} {{ redis_port | default(6379) }} {{ sentinel_quorum }}

{% if redis_password is defined %}
sentinel auth-pass {{ redis_master_name | default('mymaster') }} {{ redis_password }}
{% endif %}

{% if sentinel_password is defined %}
requirepass {{ sentinel_password }}
{% endif %}

sentinel down-after-milliseconds {{ redis_master_name | default('mymaster') }} {{ sentinel_down_after_milliseconds | default(30000) }}
sentinel failover-timeout {{ redis_master_name | default('mymaster') }} {{ sentinel_failover_timeout | default(180000) }}
sentinel parallel-syncs {{ redis_master_name | default('mymaster') }} {{ sentinel_parallel_syncs | default(1) }}

